-- =============================================
-- ФУНКЦИЯ ФЛИНГА
-- =============================================
local function flingByNames(inputText)
    if not inputText or inputText == "" then
        status.Text = "❌ DIRSTBRO: Введи ники!"
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    local names = parseNames(inputText)
    if #names == 0 then
        status.Text = "❌ DIRSTBRO: Ники не найдены"
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    local foundPlayers = {}
    local notFound = {}
    
    for _, name in ipairs(names) do
        local target = Players:FindFirstChild(name)
        if target and target ~= p then
            table.insert(foundPlayers, target)
        else
            table.insert(notFound, name)
        end
    end
    
    if #foundPlayers == 0 then
        status.Text = "❌ DIRSTBRO: Никто не найден: " .. table.concat(notFound, ", ")
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    
    local statusText = "💥 DIRSTBRO флингует: "
    for _, plr in ipairs(foundPlayers) do
        statusText = statusText .. plr.Name .. ", "
        pcall(function()
            kawasakiFling(plr)
        end)
        task.wait(0.2)
    end
    statusText = statusText:sub(1, -3) .. " ✅"
    status.Text = statusText
    status.TextColor3 = Color3.fromRGB(0, 255, 100)
    
    if #notFound > 0 then
        status.Text = status.Text .. " (не найдены: " .. table.concat(notFound, ", ") .. ")"
    end
end

-- =============================================
-- ОБРАБОТЧИКИ
-- =============================================
flingBtn.MouseButton1Click:Connect(function()
    flingByNames(input.Text)
end)

input.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        flingByNames(input.Text)
    end
end)

print("🔪 DIRSTBRO Fling GUI загружен! | Made for DIRSTBRO")
