-- FLING ПО НИКУ (НЕСКОЛЬКО ИГРОКОВ)
-- МОДИФИЦИРОВАНО ДЛЯ DIRSTBRO
local p = game.Players.LocalPlayer
local Players = game:GetService("Players")

-- =============================================
-- ФЛИНГ ТЕХНОЛОГИЯ КОВАСАКИ
-- =============================================
local function kawasakiFling(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    local char = p.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not tRoot then return end
    
    for i = 1, 3 do
        local dir = (tRoot.Position - root.Position).Unit
        root.CFrame = CFrame.new(tRoot.Position) * CFrame.new(0, 5, 0) * CFrame.Angles(0, math.rad(i * 120), 0)
        root.Velocity = dir * 9e7 + Vector3.new(0, 9e7, 0)
        root.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
        task.wait(0.05)
    end
end

-- =============================================
-- ФУНКЦИЯ ПАРСИНГА НИКОВ
-- =============================================
local function parseNames(input)
    local names = {}
    for name in string.gmatch(input, "[^,]+") do
        local trimmed = name:gsub("^%s*(.-)%s*$", "%1") -- убираем пробелы
        if trimmed ~= "" then
            table.insert(names, trimmed)
        end
    end
    return names
end

